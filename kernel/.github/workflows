name: Kernel Build 4.19

on:
  push:
    branches:
      - master
  pull_request:
  workflow_dispatch: # Allows manual run

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      # Checkout the full kernel source
      - name: Checkout kernel source
        uses: actions/checkout@v4
        with:
          submodules: true

      # Install build dependencies
      - name: Install dependencies
        run: |
          sudo apt-get update
          sudo apt-get install -y bc bison build-essential ccache curl flex git \
            libncurses-dev libssl-dev lld llvm make python3 unzip wget xz-utils zip

      # Cache ccache
      - name: Cache ccache
        uses: actions/cache@v4
        with:
          path: ~/.ccache
          key: ${{ runner.os }}-ccache-${{ github.ref_name }}
          restore-keys: |
            ${{ runner.os }}-ccache-

      # Download GCC 4.9
      - name: Download GCC 4.9
        run: |
          git clone --depth=1 https://android.googlesource.com/platform/prebuilts/gcc/linux-x86/aarch64/aarch64-linux-android-4.9 -b android11-release gcc-4.9

      # Download Clang
      - name: Download Clang
        run: |
          wget https://android.googlesource.com/platform/prebuilts/clang/host/linux-x86/+archive/refs/heads/android10-dev/clang-r353983c.tar.gz -O clang.tar.gz
          mkdir clang && tar -xf clang.tar.gz -C clang

      # Setup toolchain PATH
      - name: Setup toolchain PATH
        run: |
          echo "$GITHUB_WORKSPACE/clang/bin:$GITHUB_WORKSPACE/gcc-4.9/bin:/usr/bin:/bin" >> $GITHUB_PATH

      # Setup ccache
      - name: Setup ccache
        run: |
          mkdir -p ~/.ccache/bin
          ln -sf $(which ccache) ~/.ccache/bin/clang
          ln -sf $(which ccache) ~/.ccache/bin/clang++
          ln -sf $(which ccache) ~/.ccache/bin/aarch64-linux-android-gcc
          ln -sf $(which ccache) ~/.ccache/bin/aarch64-linux-android-g++
          echo "$HOME/.ccache/bin:$PATH" >> $GITHUB_PATH

      # Build kernel
      - name: Build kernel
        run: |
          set -e
          export KBUILD_BUILD_USER="snowluna"
          export KBUILD_BUILD_HOST="android-build"

          echo "=== Starting kernel build process ==="
          
          # Navigate to kernel directory
          cd kernel
          
          echo "Current directory: $(pwd)"
          
          # Verify Makefile exists
          if [ ! -f "Makefile" ]; then
            echo "ERROR: Makefile not found in kernel directory!"
            exit 1
          fi
          
          # Verify defconfig exists
          if [ ! -f "arch/arm64/configs/oppo6765_defconfig" ]; then
            echo "ERROR: oppo6765_defconfig not found!"
            echo "Available defconfigs:"
            ls arch/arm64/configs/ | head -20
            exit 1
          fi
          
          echo "✅ Found defconfig: arch/arm64/configs/oppo6765_defconfig"
          
          # Create output directory
          mkdir -p out
          
          # Load device defconfig
          echo "=== Loading defconfig ==="
          make O=out ARCH=arm64 oppo6765_defconfig
          
          # Build kernel
          echo "=== Building kernel with $(nproc --all) cores ==="
          make -j$(nproc --all) \
            ARCH=arm64 \
            O=out \
            CC=clang \
            CROSS_COMPILE="$GITHUB_WORKSPACE/gcc-4.9/bin/aarch64-linux-android-" \
            CLANG_TRIPLE=aarch64-linux-gnu-
          
          echo "=== Build completed successfully ==="
          
          # Verify kernel image was created
          if [ -f "out/arch/arm64/boot/Image.gz-dtb" ]; then
            echo "✅ Kernel image created: out/arch/arm64/boot/Image.gz-dtb"
            ls -lh out/arch/arm64/boot/Image.gz-dtb
          else
            echo "❌ Kernel image not created!"
            echo "Files in out/arch/arm64/boot/:"
            ls -la out/arch/arm64/boot/ || echo "Directory not found"
            exit 1
          fi

      # Show ccache stats
      - name: Show ccache stats
        run: ccache -s || true

      # Prepare flashable files
      - name: Prepare flashable files
        run: |
          set -e
          echo "=== Preparing flashable files ==="
          
          # Create artifact directory
          mkdir -p artifact
          
          # Copy kernel image from kernel/out directory
          cp kernel/out/arch/arm64/boot/Image.gz-dtb artifact/
          echo "✅ Copied kernel image"
          
          # Extract kernel version
          cd kernel
          KVER=$(awk '/^VERSION =/ {v=$3} /^PATCHLEVEL =/ {p=$3} /^SUBLEVEL =/ {s=$3} END {print v"."p"."s}' Makefile)
          cd $GITHUB_WORKSPACE
          
          echo "Kernel version: $KVER"
          echo "KVER=$KVER" >> $GITHUB_ENV
          
          # Clone AnyKernel3
          git clone --depth=1 https://github.com/NyxNoirXD/AnyKernel3.git ak
          
          # Copy AnyKernel3 files
          cp -r ak/* artifact/
          echo "✅ Copied AnyKernel3 files"
          
          # List artifact contents
          echo "=== Artifact contents ==="
          ls -la artifact/

      # Upload artifact
      - name: Upload flashable artifact
        uses: actions/upload-artifact@v4
        with:
          name: lunacore-${{ env.KVER }}
          path: artifact/*
